# workflow-backend environment example
# Copy this file to .env and adjust values for your environment.

# Required: PostgreSQL connection string used by api-service.
DATABASE_URL=postgres://workspace_adapter:workspace_adapter@localhost:5432/workspace_adapter?sslmode=disable

# Optional: HTTP port for api-service. Default: 8081
PORT=8081

# Optional: Base URL for workspace-github-adapter adapter-service.
# Use http://adapter-service:8080 when both services run in Docker on the same network.
ADAPTER_SERVICE_URL=http://localhost:8080

# Optional: Minutes after which a successful sync is considered stale. Default: 30
STALE_THRESHOLD_MINUTES=30

# Optional: Gin mode. Use debug for local development, release for production.
GIN_MODE=debug
